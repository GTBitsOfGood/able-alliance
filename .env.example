MONGODB_URI=mongodb://localhost:27017/able-alliance

# SuperAdmin — seeded on server startup if not already in DB
SUPERADMIN_EMAIL=superadmin@gatech.edu
SUPERADMIN_FIRSTNAME=Super
SUPERADMIN_LASTNAME=Admin

# NextAuth
NEXTAUTH_SECRET=dev-secret-change-in-production
DEPLOY_PRIME_URL=http://localhost:3000

# CAS Authentication
# Server-to-server CAS URL (e.g. use http://cas:8443/cas when running in Docker)
CAS_BASE_URL=http://localhost:8443/cas
# Browser-facing URL (used for login redirects visible to the user)
CAS_BASE_URL_BROWSER=http://localhost:8443/cas

# Juno (email / API)
JUNO_API_KEY=your-juno-api-key
JUNO_BASE_URL=https://api-gateway.whitesmoke-cea9a269.eastus.azurecontainerapps.io/
JUNO_EMAIL_SENDER_EMAIL=bitsgood85@gmail.com
JUNO_EMAIL_SENDER_NAME=Able Alliance

# WebSocket server for real-time chat
NEXT_PUBLIC_WS_URL=http://localhost:4000

NEXT_PUBLIC_MAPBOX_TOKEN="put token here"
